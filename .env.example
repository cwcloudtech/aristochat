# JSON array of agents, e.g.:
# AGENTS_ENDPOINTS=[{\"name\":\"cwc\",\"url\":\"https://cwc.cwcloud.tech\",\"headers\":{\"Authorization\":\"Bearer <token>\"}}]
#
# Note: this value is injected into the built JS bundle at container startup via
# envsubst (see .docker/nginx/docker-entrypoint.sh), inside an already-quoted JS
# string. Any double quote in the JSON MUST be backslash-escaped (\") as shown
# above, otherwise the substitution breaks the generated JavaScript.
AGENTS_ENDPOINTS=[]
